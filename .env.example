# Example .env file — copy this to `.env` (gitignored) and fill in real values.
#
# Loading a .env file:
#   from src.data.env import load_dotenv; load_dotenv()
# Or in your shell:
#   set -a; source .env; set +a   # bash
#   set -a; source .env; set +a   # zsh

# ── Hugging Face ─────────────────────────────────────────────
# Your Hugging Face user access token. Required for accessing gated
# datasets and for pushing the resulting model back to the Hub.
# Get one from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_replace_me_with_your_token


# ── Optional: wandb (for loss / metric logging during training) ─
# WANDB_API_KEY=replace_me

# ── Optional: explicit data paths ─────────────────────────────
# ATTNRES_DATA_ROOT=./data
# ATTNRES_CACHE_DIR=./data/raw
# ATTNRES_OUTPUT_DIR=./data/processed
